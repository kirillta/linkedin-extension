{
  "manifest_version": 3,
  "name": "LinkedIn People Page Tracker",
  "version": "1.0.0",
  "description": "Track LinkedIn companies whose People pages you've visited and mark them with a checkmark across the site.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "palette.js",
        "storage-utils.js",
        "company-tracker.js",
        "role-highlighter.js",
        "member-hider.js",
        "connect-promoter.js",
        "invitation-tracker.js",
        "withdrawal-tracker.js",
        "prospect-scorer.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn People Page Tracker",
    "default_icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
